{
  "manifest_version": 2,
  "name": "ZotFlow Auto-Sync",
  "version": "0.1.0",
  "description": "Automatically updates Obsidian ZotFlow vault files when Zotero annotations change",
  "author": "local",
  "applications": {
    "zotero": {
      "id": "zotflow-autosync@local",
      "update_url": "https://github.com/112345brian/zotero-zotflow-autosync/releases/latest/download/updates.json",
      "strict_min_version": "7.0",
      "strict_max_version": "10.*"
    }
  }
}
